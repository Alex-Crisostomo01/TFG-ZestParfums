package com.example.demo.model;
import jakarta.persistence.*;
import lombok.Data;

@Entity // Define esta clase como una tabla MySql
@Table(name="perfumes") // tiene que ser el mismo nombre que en el .sql
@Data // crea getters setters ToStrings y equals automaticamente
public class Perfume {
	@Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;

    @Column(name = "nombre") // Coincide con la columna de la BBDD
    private String nombre;

    private String marca;
    
    private Double precio;

    private Integer stock;

    @Column(name = "imagen_url")
    private String imagenUrl;
}
